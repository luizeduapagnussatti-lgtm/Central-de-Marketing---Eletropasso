# Ambiente
APP_ENV=development
APP_BASE_URL=http://localhost/Central%20de%20marketing_dev/

# Banco de dados
MARKETING_DB_HOST=127.0.0.1
MARKETING_DB_PORT=3306
MARKETING_DB_NAME=central_marketing_eletropasso
MARKETING_DB_USER=root
MARKETING_DB_PASS=
MARKETING_DB_CHARSET=utf8mb4

# Gemini API (texto: nomes e titulos)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Rembg — remocao de fundo offline (pip install rembg[cli])
REMBG_BIN=rembg
REMBG_MODEL=u2net
REMBG_MAX_EDGE=1280
REMBG_ALPHA_MATTING=0
REMBG_POST_PROCESS_MASK=0
REMBG_WHITE_REFINE=1
REMBG_WHITE_TOLERANCE=42

# Hub de Precificacao
HUB_API_URL=http://localhost/orcador_dev/api/marketing/produto.php
HUB_API_TOKEN=

# Upload
MAX_UPLOAD_SIZE_MB=10

# Puppeteer
NODE_BIN=C:\Program Files\nodejs\node.exe
PUPPETEER_TIMEOUT_MS=30000
